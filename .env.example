# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=WorldLive
APP_ENV=development          # development | production
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Admin Account (single-user self-hosted mode) ─────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=worldlive-admin

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=worldlive
POSTGRES_USER=worldlive
POSTGRES_PASSWORD=worldlive-secret
DATABASE_URL=postgresql+asyncpg://worldlive:worldlive-secret@postgres:5432/worldlive

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CesiumJS ─────────────────────────────────────────────────────────────────
# Optional — get a free token at https://ion.cesium.com
# Leave blank to use OpenStreetMap tiles (no account required)
VITE_CESIUM_ION_TOKEN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Collector Intervals (seconds) ────────────────────────────────────────────
EARTHQUAKES_INTERVAL=60
WEATHER_INTERVAL=300
SATELLITES_INTERVAL=30
VOLCANOES_INTERVAL=600
WILDFIRES_INTERVAL=300
AIRQUALITY_INTERVAL=180

# ─── NASA FIRMS ───────────────────────────────────────────────────────────────
# Free MAP_KEY from https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_MAP_KEY=

# ─── OpenAQ ───────────────────────────────────────────────────────────────────
OPENAQ_API_KEY=
